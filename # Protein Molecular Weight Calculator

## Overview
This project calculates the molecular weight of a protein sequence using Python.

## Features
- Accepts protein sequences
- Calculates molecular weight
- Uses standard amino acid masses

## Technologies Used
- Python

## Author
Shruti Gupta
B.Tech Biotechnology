protein = input("Enter Protein Sequence: ").upper()

weights = {
    'A': 89.1,
    'R': 174.2,
    'N': 132.1,
    'D': 133.1,
    'C': 121.2,
    'Q': 146.2,
    'E': 147.1,
    'G': 75.1,
    'H': 155.2,
    'I': 131.2,
    'L': 131.2,
    'K': 146.2,
    'M': 149.2,
    'F': 165.2,
    'P': 115.1,
    'S': 105.1,
    'T': 119.1,
    'W': 204.2,
    'Y': 181.2,
    'V': 117.1
}

total_weight = 0

for amino_acid in protein:
    if amino_acid in weights:
        total_weight += weights[amino_acid]

print("Molecular Weight:", round(total_weight, 2), "Da")